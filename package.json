{
  "name": "symbol-openapi",
  "version": "1.0.5",
  "description": "OpenAPI Specification of catapult-rest",
  "main": "index.js",
  "scripts": {
    "lint:yaml:setup": "python3 -m venv .venv && .venv/bin/python -m pip install yamllint",
    "lint:yaml": ".venv/bin/python -m yamllint -c .yamllint _build/openapi3.yml",
    "lint:openapi": "redocly lint _build/openapi3.yml",
    "lint": "npm run build && npm run lint:yaml && npm run lint:openapi",
    "test": "npm run lint && npm run verify-links",
    "verify-links": "markdown-link-check _build/openapi3.yml -c .markdown-link-check.json -q",
    "build": "redocly bundle spec/openapi.yml -o _build/openapi3.yml",
    "postman": "openapi2postmanv2 -s _build/openapi3.yml -o _build/postman.json -p",
    "version": "echo $npm_package_version",
    "version:prepare": "mkdir _build/v$npm_package_version && cp -r _build/template/. _build/v$npm_package_version",
    "version:pack": "cp _build/openapi3.yml _build/postman.json _build/v$npm_package_version"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/symbol/symbol-openapi.git"
  },
  "license": "Apache 2.0",
  "bugs": {
    "url": "https://github.com/symbol/symbol-openapi/issues"
  },
  "homepage": "https://github.com/symbol/symbol-openapi#readme",
  "dependencies": {},
  "devDependencies": {
    "@redocly/cli": "^1.25.0",
    "markdown-link-check": "^3.14.2",
    "openapi-to-postmanv2": "^6.0.0"
  }
}
